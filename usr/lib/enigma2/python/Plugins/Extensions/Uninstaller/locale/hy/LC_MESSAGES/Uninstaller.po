msgid "Choose and uninstall an addon package"
msgstr "Ընտրեք և տեղահանեք հավելումների փաթեթը"

msgid "Error Unknow"
msgstr "Սխալ Չգիտեմ"

msgid "Force Remove"
msgstr "Ստիպել հեռացնել"

msgid "Force Removing ipk %s"
msgstr "Ստիպել հեռացնել ipk %s-ը"

msgid "Please Select the Package to Remove"
msgstr "Խնդրում ենք ընտրել Փաթեթը, որը պետք է հեռացնել"

msgid "Please advise on forum board for issue!"
msgstr "Խնդրում ենք խորհուրդ տալ ֆորումի տախտակին խնդրի համար:"

msgid "Remove"
msgstr "Հեռացնել"

msgid "Removing dpkg %s"
msgstr "dpkg %s-ի հեռացում"

msgid "Removing ipk %s"
msgstr "ipk %s-ի հեռացում"

msgid "Select method:"
msgstr "Ընտրեք մեթոդ."

msgid "Uninstaller"
msgstr "Ապատեղադրող"

msgid "Wait Please..."
msgstr "Սպասեք, խնդրում եմ..."
