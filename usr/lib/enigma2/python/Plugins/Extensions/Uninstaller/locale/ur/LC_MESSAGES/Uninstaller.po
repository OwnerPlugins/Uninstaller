msgstr "ہٹا دیں۔"

msgid "Removing dpkg %s"
msgstr "dpkg %s کو ہٹایا جا رہا ہے۔"

msgid "Removing ipk %s"
msgstr "ipk %s کو ہٹایا جا رہا ہے۔"

msgid "Select method:"
msgstr "طریقہ منتخب کریں:"

msgid "Uninstaller"
msgstr "ان انسٹالر"

