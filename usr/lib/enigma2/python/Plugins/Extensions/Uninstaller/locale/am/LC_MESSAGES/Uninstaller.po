msgid "Choose and uninstall an addon package"
msgstr "የአዶን ጥቅል ይምረጡ እና ያራግፉ"

msgid "Error Unknow"
msgstr "ያልታወቀ ስህተት"

msgid "Force Remove"
msgstr "አስወግድ"

msgid "Force Removing ipk %s"
msgstr "ipk %sን ለማስወገድ ያስገድዱ"

msgid "Please Select the Package to Remove"
msgstr "እባክዎ ለማስወገድ ጥቅሉን ይምረጡ"

msgid "Please advise on forum board for issue!"
msgstr "እባክዎን ለጉዳዩ መድረክ ቦርድ ላይ ምክር ይስጡ!"

msgid "Remove"
msgstr "አስወግድ"

msgid "Removing dpkg %s"
msgstr "dpkg %sን በማስወገድ ላይ"

msgid "Removing ipk %s"
msgstr "ipk %sን በማስወገድ ላይ"

msgid "Select method:"
msgstr "ዘዴ ይምረጡ፡-"

msgid "Uninstaller"
msgstr "ማራገፊያ"

msgid "Wait Please..."
msgstr "ቆይ እባክህ..."
