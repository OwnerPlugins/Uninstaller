msgid "Please advise on forum board for issue!"
msgstr "ਕਿਰਪਾ ਕਰਕੇ ਮੁੱਦੇ ਲਈ ਫੋਰਮ ਬੋਰਡ 'ਤੇ ਸਲਾਹ ਦਿਓ!"

msgid "Remove"
msgstr "ਹਟਾਓ"

msgid "Removing dpkg %s"
msgstr "dpkg %s ਨੂੰ ਹਟਾਇਆ ਜਾ ਰਿਹਾ ਹੈ"

msgid "Removing ipk %s"
msgstr "ipk %s ਨੂੰ ਹਟਾਇਆ ਜਾ ਰਿਹਾ ਹੈ"

msgid "Select method:"
msgstr "ਵਿਧੀ ਚੁਣੋ:"

msgid "Uninstaller"
msgstr "ਅਣਇੰਸਟੌਲਰ"

msgid "Wait Please..."
msgstr "ਉਡੀਕ ਕਰੋ ਜੀ..."
