msgid "Choose and uninstall an addon package"
msgstr "ਇੱਕ ਐਡਆਨ ਪੈਕੇਜ ਚੁਣੋ ਅਤੇ ਅਣਇੰਸਟੌਲ ਕਰੋ"

msgid "Error Unknow"
msgstr "ਗਲਤੀ ਅਣਜਾਣ"

msgid "Force Remove"
msgstr "ਜ਼ਬਰਦਸਤੀ ਹਟਾਓ"

msgid "Force Removing ipk %s"
msgstr "ipk %s ਨੂੰ ਹਟਾਉਣ ਲਈ ਜ਼ਬਰਦਸਤੀ ਕਰੋ"

msgid "Please Select the Package to Remove"
